{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "billing-engine": ["./packages/billing-engine/src/index.ts"],
      "billing-engine/next/handlers": ["./packages/billing-engine/src/next/handlers/index.ts"],
      "billing-engine/next/components": ["./packages/billing-engine/src/next/components/index.ts"],
      "billing-engine/models": ["./packages/billing-engine/src/models/index.ts"],
      "billing-engine/subscriptionAccess": ["./packages/billing-engine/src/billing/subscriptionAccess.ts"],
      "billing-engine/pricing-display": ["./packages/billing-engine/src/billing/pricingPlanDisplay.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
