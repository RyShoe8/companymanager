# Copy to .env.local and fill in values

MONGODB_URI=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

BREVO_API_KEY=
BREVO_SENDER_EMAIL=theteam@nucleas.app
BREVO_SENDER_NAME=Nucleas

# Google sign-in (openid email profile)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Google Calendar (Workspace → Schedule). Register this URI in GCP Authorized redirect URIs.
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/scheduling/google/callback
# Google Drive / Docs / Sheets (smart button). Register in GCP Authorized redirect URIs.
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/google/workspace/callback
# Required for Google Picker (attach from Drive). Enable Picker API in GCP.
NEXT_PUBLIC_GOOGLE_API_KEY=
# Required in production. Encrypts Google Calendar refresh tokens at rest (AES-256-GCM).
CALENDAR_TOKEN_ENCRYPTION_KEY=

OPENAI_API_KEY=

# Stripe billing (omit STRIPE_SECRET_KEY in dev to treat all orgs as paid)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Bearer secret for /api/cron/* routes (Vercel cron or external scheduler). Cron fails closed if unset.
CRON_SECRET=

# One-time platform setup secret for /api/admin/setup.
PLATFORM_SETUP_SECRET=

# Vercel Blob storage (recording + logo uploads).
BLOB_READ_WRITE_TOKEN=

# Public base URL used in emails and links (falls back to NEXTAUTH_URL).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog product analytics (client-side; set in Vercel for production/preview).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional Twitter handle for sitewide card attribution (e.g. @nucleas).
NEXT_PUBLIC_TWITTER_SITE=

# Google reCAPTCHA v3 (public forms: contact, auth, book-call). Create keys at https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Optional minimum score threshold (0.0–1.0). Defaults to 0.5.
RECAPTCHA_MIN_SCORE=0.5
